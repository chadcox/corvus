# PostgreSQL
POSTGRES_USER=forensicflow
POSTGRES_PASSWORD=forensicflow
POSTGRES_DB=forensicflow

# API
DATABASE_URL=postgresql+psycopg://forensicflow:forensicflow@postgres:5432/forensicflow
REDIS_URL=redis://redis:6379/0
EVIDENCE_ROOT=/data/evidence
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Worker
EZTOOLS_ROOT=/opt/eztools
SIGMA_REF=master
# dfir = IR-focused subset at load time; full = all bundled rules
SIGMA_PROFILE=dfir
# Pull Sigma rules from GitHub every N hours (0 = scheduled refresh disabled)
SIGMA_REFRESH_INTERVAL_HOURS=24

# Chainsaw (WithSecure native rules + optional Sigma-via-Chainsaw)
CHAINSAW_ENABLED=true
CHAINSAW_INCLUDE_SIGMA=true
# Sigma tier for Chainsaw hunt: dfir (~1400 rules), full (all bundled), off (native Chainsaw only)
CHAINSAW_SIGMA_PROFILE=dfir
# EVTX selection: priority (Security/Sysmon/PowerShell first) or all
CHAINSAW_EVTX_MODE=priority
CHAINSAW_EVTX_MAX=64
CHAINSAW_EVTX_PARALLEL=4
CHAINSAW_EVTX_BATCH_SIZE=16
CHAINSAW_HUNT_BATCH_TIMEOUT_SECONDS=300
CHAINSAW_REF=master

# Hindsight — Chromium browser forensics (RyanDFIR/hindsight)
HINDSIGHT_ENABLED=true
HINDSIGHT_MAX_PROFILES=8
HINDSIGHT_TIMEOUT_SECONDS=900

# Optional permissive macOS/Linux parser tooling.
# false keeps normal builds fast/stable; true installs Plaso and mac_apt in worker images.
INSTALL_OPEN_FORENSICS=false
WORKER_TOOLS_IMAGE=forensicflow-worker:tools
PLASO_ENABLED=true
MAC_APT_ENABLED=true
VOLATILITY3_ENABLED=true
VOLATILITY3_BIN=vol
VOLATILITY3_PLUGINS=windows.info,windows.pslist,windows.netscan,windows.cmdline
INSTALL_VOLATILITY3=true

# API validation (automated ingest tests)
SAMPLES_ROOT=/samples
ENABLE_VALIDATION_API=false

# Admin / dev endpoints (overview, job list, route catalog, purge validation cases)
ENABLE_ADMIN_API=false
API_VERSION=0.1.0
# Deployment environment: development (default) | staging | production.
# In staging/production the app refuses to start with the default or a <32-char AUTH_SECRET_KEY.
ENVIRONMENT=development
AUTH_SECRET_KEY=change-me-dev-auth-secret
AUTH_JWT_ALGORITHM=HS256
AUTH_TOKEN_EXP_MINUTES=480
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
AUTH_BOOTSTRAP_ADMIN_PASSWORD=
DOCKER_COMPOSE_PROJECT=forensicflow

# Upload safety limits
UPLOAD_MAX_BYTES=10737418240
EXTRACTED_MAX_FILES=250000
EXTRACTED_MAX_BYTES=536870912000
DELETE_EVIDENCE_AFTER_INGEST=false

# Web (dev)
VITE_API_URL=http://localhost:8000
